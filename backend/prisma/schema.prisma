generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organisation {
  id          String       @id @default(uuid())
  name        String
  createdAt   DateTime     @default(now())
  users       User[]
  departments Department[]
  queryLogs   QueryLog[]
  conversations Conversation[]
}

model Department {
  id            String       @id @default(uuid())
  name          String
  description   String?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  
  organisation  Organisation @relation(fields: [organisationId], references: [id])
  organisationId String
  
  users         User[]
  queryLogs     QueryLog[]
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  passwordHash String
  role         String       @default("user")
  createdAt    DateTime     @default(now())
  
  organisation Organisation? @relation(fields: [organisationId], references: [id])
  organisationId String?
  
  department   Department?  @relation(fields: [departmentId], references: [id])
  departmentId String?
  
  documents    Document[]
  queryLogs    QueryLog[]
  conversations Conversation[]
  memories     ConversationMemory[]
}

model Document {
  id          String   @id @default(uuid())
  fileName    String
  fileSize    Int
  fileType    String
  filePath    String   // Path where file is stored on disk
  uploadedAt  DateTime @default(now())
  uploadedBy  String   // User ID who uploaded
  
  // AI Service data - collection ID for all chunks
  numChunks   Int      // Number of chunks created
  documentId  String   @unique  // Single collection ID - deleting this deletes all child chunks

  // Ingestion progress and status (for async processing lifecycle)
  status          IngestionStatus @default(QUEUED)
  failedReason    String?
  processedChunks Int             @default(0)
  totalChunks     Int             @default(0)
  
  // Relations
  user        User     @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)
  
  @@index([uploadedBy])
}

enum IngestionStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

model QueryLog {
  id        String        @id @default(uuid())
  userId    String
  orgId     String?
  departmentId String?     @map("department_id")
  question  String
  response  String
  responseTimeMs Int       @map("response_time_ms")
  documentIdsUsed String[] @default([]) @map("document_ids_used")
  createdAt DateTime      @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organisation Organisation? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  department   Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([orgId])
  @@index([departmentId])
  @@index([createdAt])
}

model Conversation {
  id             String        @id @default(uuid())
  userId         String
  organisationId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  memories       ConversationMemory[]

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organisation Organisation? @relation(fields: [organisationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([organisationId])
  @@index([createdAt])
}

model ConversationMemory {
  id             String       @id @default(uuid())
  conversationId String
  userId         String
  role           String
  content        String
  createdAt      DateTime     @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([userId])
  @@map("conversation_memory")
}
